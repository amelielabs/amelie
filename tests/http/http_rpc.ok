open E0 "uuid": "00000000-0000-0000-0000-000000000000", "listen": [{ "host": "127.0.0.1", "port": 3485 }];
connect E0 S0 127.0.0.1:3485;
# test: POST /rpc
post /rpc - - -;
{"jsonrpc": "2.0", "id": 0, "error": {"code": -32000, "message": "unexpected end of line"}}
# test: POST /rpc (invalid content type)
post /rpc xyx - -;
400 Bad Request
# test: POST /rpc (mandatory fields)
post /rpc application/json - {"jsonrpc": "2.0"} ;
{"jsonrpc": "2.0", "id": 0, "error": {"code": -32000, "message": "jsonrpc: invalid request"}}
post /rpc application/json - {"jsonrpc": "2.0", "id": 11};
{"jsonrpc": "2.0", "id": 0, "error": {"code": -32000, "message": "jsonrpc: invalid request"}}
post /rpc application/json - {"jsonrpc": "2.0", "method": sql};
{"jsonrpc": "2.0", "id": 0, "error": {"code": -32000, "message": "unexpected json token"}}
# test: POST /rpc (sql, no params)
post /rpc application/json - {"jsonrpc": "2.0", "id": 11, "method": "sql"};
{"jsonrpc": "2.0", "id": 0, "error": {"code": -32000, "message": "'params' field is missing"}}
# test: POST /rpc (sql, params validatation)
post /rpc application/json - {"jsonrpc": "2.0", "id": 11, "method": "sql", "params": 1};
{"jsonrpc": "2.0", "id": 0, "error": {"code": -32000, "message": "'params' field is not an object"}}
post /rpc application/json - {"jsonrpc": "2.0", "id": 11, "method": "sql", "params": []};
{"jsonrpc": "2.0", "id": 0, "error": {"code": -32000, "message": "'params' field is not an object"}}
post /rpc application/json - {"jsonrpc": "2.0", "id": 11, "method": "sql", "params": {}};
{"jsonrpc": "2.0", "id": 0, "error": {"code": -32000, "message": "'text' field is not defined"}}
post /rpc application/json - {"jsonrpc": "2.0", "id": 11, "method": "sql", "params": {"a": "b"}};
{"jsonrpc": "2.0", "id": 0, "error": {"code": -32000, "message": "unexpected params field"}}
# test: POST /rpc (sql)
post /rpc application/json - {"jsonrpc": "2.0", "id": 11, "method": "sql", "params": {"text": "select 1"}};
{"jsonrpc": "2.0", "id": 0, "result": {"columns": ["col1"], "rows": [[1]]}}
# test: POST /rpc (insert)
create table test (id int primary key, data int default 11);
post /rpc - - {"jsonrpc": "2.0", "id": 11, "method": "write", "params": {"rel": "test", "args": [] }};
select * from test;
post /rpc - - {"jsonrpc": "2.0", "id": 11, "method": "write", "params": {"rel": "test", "args": {} }};
{"jsonrpc": "2.0", "id": 0, "error": {"code": -32000, "message": "column 'id' value cannot be NULL"}}
select * from test;
post /rpc - - {"jsonrpc": "2.0", "id": 11, "method": "write", "params": {"rel": "test", "args": {"id": 18} }};
select * from test;
18 │ 11
post /rpc - - {"jsonrpc": "2.0", "id": 11, "method": "write", "params": {"rel": "test", "args": {"id": 19, "data": null} }};
select * from test;
18 │ 11
19 │ null
post /rpc - - {"jsonrpc": "2.0", "id": 11, "method": "write", "params": {"rel": "test", "args": [{"id": 20}, {"id": 21}] }};
select * from test;
18 │ 11
19 │ null
20 │ 11
21 │ 11
drop table test;
# test: POST /rpc (execute)
create function x (a int, b int) return int
begin
	return a + b;
end;
post /rpc - - {"jsonrpc": "2.0", "id": 11, "method": "write", "params": {"rel": "x", "args": [] }};
{"jsonrpc": "2.0", "id": 0, "result": {"columns": ["x"], "rows": [[null]]}}
post /rpc - - {"jsonrpc": "2.0", "id": 11, "method": "write", "params": {"rel": "x", "args": {} }};
{"jsonrpc": "2.0", "id": 0, "result": {"columns": ["x"], "rows": [[null]]}}
post /rpc - - {"jsonrpc": "2.0", "id": 11, "method": "write", "params": {"rel": "x", "args": {"a": 1, "b": 2} }};
{"jsonrpc": "2.0", "id": 0, "result": {"columns": ["x"], "rows": [[3]]}}
disconnect S0;
close E0;
