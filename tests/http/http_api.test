#

open E0 "uuid": "00000000-0000-0000-0000-000000000000", "listen": [{ "host": "127.0.0.1", "port": 3485 }];
connect E0 S0 127.0.0.1:3485;

# test: POST /api
post /api - - -;

# test: POST /api (invalid content type)
post /api xyx - -;

# test: POST /api (mandatory fields)
post /api application/json - {"jsonrpc": "2.0"} ;
post /api application/json - {"jsonrpc": "2.0", "id": 11};
post /api application/json - {"jsonrpc": "2.0", "method": sql};
post /api application/json - {"jsonrpc": "2.0", "id": 11, "method": "sql"};

# test: POST /api (sql, no params)
post /api application/json - {"jsonrpc": "2.0", "id": 11, "method": "amelie/sql"};

# test: POST /api (sql, params validatation)
post /api application/json - {"jsonrpc": "2.0", "id": 11, "method": "amelie/sql", "params": 1};
post /api application/json - {"jsonrpc": "2.0", "id": 11, "method": "amelie/sql", "params": []};
post /api application/json - {"jsonrpc": "2.0", "id": 11, "method": "amelie/sql", "params": {}};
post /api application/json - {"jsonrpc": "2.0", "id": 11, "method": "amelie/sql", "params": {"a": "b"}};

# test: POST /api (sql)
post /api application/json - {"jsonrpc": "2.0", "id": 11, "method": "amelie/sql", "params": {"text": "select 1"}};
post /api application/json - {"jsonrpc": "2.0", "id": 11, "method": "amelie/sql", "params": {"text": "explain select 1"}};

# test: POST /api (sql, validate id)
post /api application/json - {"jsonrpc": "2.0", "id": null, "method": "amelie/sql", "params": {"text": "select 1"}};
post /api application/json - {"jsonrpc": "2.0", "id": "abc", "method": "amelie/sql", "params": {"text": "select 1"}};
post /api application/json - {"jsonrpc": "2.0", "id": [], "method": "amelie/sql", "params": {"text": "select 1"}};

# test: POST /api (insert)
create table test (id int primary key, data int default 11);
post /api - - {"jsonrpc": "2.0", "id": 11, "method": "amelie/write", "params": {"rel": "test", "args": [] }};
select * from test;

post /api - - {"jsonrpc": "2.0", "id": 11, "method": "amelie/write", "params": {"rel": "test", "args": {} }};
select * from test;

post /api - - {"jsonrpc": "2.0", "id": 11, "method": "amelie/write", "params": {"rel": "test", "args": {"id": 18} }};
select * from test;

post /api - - {"jsonrpc": "2.0", "id": 11, "method": "amelie/write", "params": {"rel": "test", "args": {"id": 19, "data": null} }};
select * from test;

post /api - - {"jsonrpc": "2.0", "id": 11, "method": "amelie/write", "params": {"rel": "test", "args": [{"id": 20}, {"id": 21}] }};
select * from test;
drop table test;

# test: POST /api (execute)
create function x (a int, b int) return int
begin
	return a + b;
end;
post /api - - {"jsonrpc": "2.0", "id": 11, "method": "amelie/write", "params": {"rel": "x", "args": [] }};
post /api - - {"jsonrpc": "2.0", "id": 11, "method": "amelie/write", "params": {"rel": "x", "args": {} }};
post /api - - {"jsonrpc": "2.0", "id": 11, "method": "amelie/write", "params": {"rel": "x", "args": {"a": 1, "b": 2} }};

# test: POST /api (execute, batch)
post /api - - {"jsonrpc": "2.0", "id": 11, "method": "amelie/write", "params": {"rel": "x", "args": [{"a": 1, "b": 2}] }};
post /api - - {"jsonrpc": "2.0", "id": 11, "method": "amelie/write", "params": {"rel": "x", "args": [{"a": 1, "b": 2}, {}] }};

disconnect S0;
close E0;
