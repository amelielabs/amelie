["test"]
select 1;
[1]
disconnect S1;
switch S0;
drop user test;
# test: drop user cascade (with relations)
create user test;
connect E0 S1 test@127.0.0.1:3485;
switch S1;
create table a(id int primary key);
create table b(id int primary key);
create function fn() begin select * from a; end;
disconnect S1;
switch S0;
drop user test;
{"msg": "user 'test' still has relations"}
drop user test cascade;
select 1;
[1]
show tables;
[]
show functions;
[]
select show('user', 'test').name;
[null]
