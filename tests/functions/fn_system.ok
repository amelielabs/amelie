  "name": "main",
  "path": "",
  "compression": "zstd",
  "compression_level": 0
}
create table test (id int primary key);
# test: tables
select show('tables');
[{
  "user": "main",
  "name": "test"
}]
# test: table
select show('table', 'test');
{
  "user": "main",
  "name": "test"
}
# test: indexes
select show('indexes', '', 'test', false);
[{
  "name": "primary",
  "type": 2,
  "unique": true,
  "primary": true,
  "keys": [{
    "column": 0,
    "asc": true
  }]
}]
