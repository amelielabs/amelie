open E0 "uuid": "00000000-0000-0000-0000-000000000000", "listen": [{ "host": "127.0.0.1", "port": 3485 }];
connect E0 S0 127.0.0.1:3485;
# test: POST uri parsing
post / - - -;
400 Bad Request
post /db - - -;
400 Bad Request
post /xyz - - -;
400 Bad Request
# test: POST /sql
post /sql - - -;
{"msg": "unsupported operation content-type"}
post /sql/ - - -;
{"msg": "unsupported operation content-type"}
# test: POST /sql (invalid content type)
post /sql - - -;
{"msg": "unsupported operation content-type"}
post /sql json - -;
{"msg": "unsupported operation content-type"}
post /sql/ application/json - -;
{"msg": "unsupported operation content-type"}
# test: POST /sql (plain/text, no accept, no content)
post /sql plain/text - -;
# test: POST /sql (plain/text, no accept)
post /sql plain/text - select 1;
{ "columns": ["col1"], "rows": [[1]] }
# test: POST /sql (plain/text, invalid accept)
post /sql plain/text xyz select 1;
400 Bad Request
# test: POST /sql (plain/text)
post /sql plain/text application/json select 1;
{ "columns": ["col1"], "rows": [[1]] }
# test: POST /sql (args parsing)
post /sql? plain/text application/json select 1;
400 Bad Request
post /sql?a plain/text application/json select 1;
400 Bad Request
post /sql plain/text application/json select "2024-07-29 18:40:19"::timestamp;
{ "columns": ["col1"], "rows": [["2024-07-29 18:40:19+00"]] }
post /sql?timezone=Asia/Tokyo plain/text application/json select "2024-07-29 18:40:19"::timestamp;
{ "columns": ["col1"], "rows": [["2024-07-29 18:40:19+09"]] }
disconnect S0;
close E0;
