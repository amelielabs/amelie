#

open E0 "uuid": "00000000-0000-0000-0000-000000000000", "listen": [{ "host": "127.0.0.1", "port": 3485 }];
connect E0 S0 127.0.0.1:3485;

# test: POST uri parsing
post / - - -;
post /db - - -;
post /xyz - - -;

# test: POST /sql
post /sql - - -;
post /sql/ - - -;

# test: POST /sql (invalid content type)
post /sql - - -;
post /sql json - -;
post /sql/ application/json - -;

# test: POST /sql (text/plain, no accept, no content)
post /sql text/plain - -;

# test: POST /sql (text/plain, no accept)
post /sql text/plain - select 1;

# test: POST /sql (text/plain, invalid accept)
post /sql text/plain xyz select 1;

# test: POST /sql (text/plain)
post /sql text/plain application/json select 1;

# test: POST /sql (args parsing)
post /sql? text/plain application/json select 1;
post /sql?a text/plain application/json select 1;

post /sql text/plain application/json select "2024-07-29 18:40:19"::timestamp;
post /sql?timezone=Asia/Tokyo text/plain application/json select "2024-07-29 18:40:19"::timestamp;

disconnect S0;
close E0;
