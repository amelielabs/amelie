open E0 "uuid": "00000000-0000-0000-0000-000000000000", "listen": [{ "host": "127.0.0.1", "port": 3485 }];
connect E0 S0 127.0.0.1:3485;
# test: ensure system users exists
show users;
[{
  "name": "main",
  "agent": false
}]
# test: create user statement parsing
create;
{"msg": "create❰;❱ ⟵ REPLICA|USER|STORAGE|TABLE|INDEX|BRANCH|FUNCTION|SYNONYM|LOCK expected"}
create user;
{"msg": "create user❰;❱ ⟵ name expected"}
create user 123;
{"msg": "create user ❰123❱ ⟵ name expected"}
create user if;
{"msg": "create user if❰;❱ ⟵ NOT expected"}
create user if not;
{"msg": "create user if not❰;❱ ⟵ EXISTS expected"}
create user if not 123;
{"msg": "create user if not ❰123❱ ⟵ EXISTS expected"}
create user if not exists;
{"msg": "create user if not exists❰;❱ ⟵ name expected"}
create user test abc;
{"msg": "create user test ❰abc❱ ⟵ ; expected"}
# test: create user
create user test;
show users;
[{
  "name": "main",
  "agent": false
}, {
  "name": "test",
  "agent": false
}]
select show('users');
[[{
  "name": "main",
  "agent": false
}, {
  "name": "test",
  "agent": false
}]]
# test: create user if not exists
create user test;
{"msg": "user 'test': already exists"}
create user if not exists test;
show users;
[{
  "name": "main",
  "agent": false
}, {
  "name": "test",
  "agent": false
}]
# test: drop user statement parsing
drop user;
{"msg": "drop user❰;❱ ⟵ name expected"}
drop user 123;
{"msg": "drop user ❰123❱ ⟵ name expected"}
drop user if;
{"msg": "drop user if❰;❱ ⟵ EXISTS expected"}
drop user if exists;
{"msg": "drop user if exists❰;❱ ⟵ name expected"}
drop user test abc;
{"msg": "drop user test ❰abc❱ ⟵ ; expected"}
# test: drop user
drop user test;
show users;
[{
  "name": "main",
  "agent": false
}]
# test: drop user if exists
drop user test;
{"msg": "user 'test': not exists"}
drop user if exists test;
show users;
[{
  "name": "main",
  "agent": false
}]
# test: drop main user
drop user main;
{"msg": "user 'main': system user cannot be dropped"}
show users;
[{
  "name": "main",
  "agent": false
}]
# test: drop user cascade
create user test;
drop user test cascade;
show users;
[{
  "name": "main",
  "agent": false
}]
# test: drop connected user
create user test;
show users;
[{
  "name": "main",
  "agent": false
}, {
  "name": "test",
  "agent": false
}]
connect E0 S1 test@127.0.0.1:3485;
switch S1;
drop user test;
select 1;
Forbidden
disconnect S1;
switch S0;
# test: drop user cascade (with relations)
create user test;
connect E0 S1 test@127.0.0.1:3485;
switch S1;
create table a(id int primary key);
create table b(id int primary key);
create function fn() begin select * from a; end;
drop user test;
{"msg": "user 'test' still has relations"}
drop user test cascade;
select 1;
Forbidden
disconnect S1;
switch S0;
show tables;
[]
show functions;
[]
show users;
[{
  "name": "main",
  "agent": false
}]
# test: alter user statment parsing
alter user;
{"msg": "alter user❰;❱ ⟵ name expected"}
alter user 123;
{"msg": "alter user ❰123❱ ⟵ name expected"}
alter user test;
{"msg": "alter user test❰;❱ ⟵ RENAME expected"}
alter user test rename;
{"msg": "alter user test rename❰;❱ ⟵ TO expected"}
alter user test rename to;
{"msg": "alter user test rename to❰;❱ ⟵ name expected"}
alter user test rename "hello";
{"msg": "alter user test rename ❰\"hello\"❱ ⟵ TO expected"}
# test: alter user rename
create user test;
show users;
[{
  "name": "main",
  "agent": false
}, {
  "name": "test",
  "agent": false
}]
alter user test rename to test2;
show users;
[{
  "name": "main",
  "agent": false
}, {
  "name": "test2",
  "agent": false
}]
drop user test2;
# test: alter user main
alter user main rename to _public;
{"msg": "user 'main': system user cannot be renamed"}
# test: alter user rename cascade (udf dep)
create user test;
connect E0 S1 test@127.0.0.1:3485;
switch S1;
create table a(id int primary key);
insert into a values (1), (2), (3);
create table b(id int primary key);
create function fn() return int
begin
	total int = 0;
	select count(*) into total from a;
	return total;
end;
select fn();
[3]
alter user test rename to test2;
{"msg": "function 'fn' depends on user 'test"}
drop function fn;
# test: alter user rename cascade
alter user test rename to test2;
select 1;
Forbidden
disconnect S1;
connect E0 S1 test2@127.0.0.1:3485;
switch S1;
show tables;
[{
  "user": "test2",
  "name": "a"
}, {
  "user": "test2",
  "name": "b"
}]
show functions;
[]
show users;
[{
  "name": "main",
  "agent": false
}, {
  "name": "test2",
  "agent": false
}]
disconnect S1;
switch S0;
show tables;
[]
show functions;
[]
show users;
[{
  "name": "main",
  "agent": false
}, {
  "name": "test2",
  "agent": false
}]
drop user test2;
{"msg": "user 'test2' still has relations"}
drop user test2 cascade;
# test: create agent
create agent test;
show users;
[{
  "name": "main",
  "agent": false
}, {
  "name": "test",
  "agent": true
}]
drop agent test;
disconnect S0;
close E0;
