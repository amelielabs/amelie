open E0 "uuid": "00000000-0000-0000-0000-000000000000", "listen": [{ "host": "127.0.0.1", "port": 3485 }];
connect E0 S0 127.0.0.1:3485;
# test: alter partition statement parsing
alter partition;
error: alter partition❰;❱ ⟵ int expected
alter partition xyz;
error: alter partition ❰xyz❱ ⟵ int expected
alter partition 1;
error: alter partition 1❰;❱ ⟵ ON expected
alter partition 1 on;
error: alter partition 1 on❰;❱ ⟵ name expected
alter partition 1 on xyz;
error: alter partition 1 on xyz❰;❱ ⟵ command expected
alter partition 1 on xyz qwerty;
error: alter partition 1 on xyz ❰qwerty❱ ⟵ unknown command
disconnect S0;
close E0;
