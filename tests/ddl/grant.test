#
open E0 "uuid": "00000000-0000-0000-0000-000000000000", "listen": [{ "host": "127.0.0.1", "port": 3485 }];
connect E0 S0 127.0.0.1:3485;

# test: default user grants
create user test;
select grants from show users verbose;

# test: create_table
connect E0 S1 test@127.0.0.1:3485;
switch S1;

create table test (id int primary key);

switch S0;
revoke create_table from test;

switch S1;
create table test2 (id int primary key);

# still possible
drop table test;
switch S0;
grant create_table to test;

# test: create_clone
switch S1;
create table test (id int primary key);
create clone test_clone of test;

switch S0;
revoke create_clone from test;

switch S1;
create clone test_clone2 of test;

# still possible
drop clone test_clone;
drop table test;
switch S0;

# test: create_topic
switch S1;
create topic test;

switch S0;
revoke create_topic from test;

switch S1;
create topic test2;

# still possible
drop topic test;
switch S0;

# test: create_function
switch S1;
create function test () begin end;

switch S0;
revoke create_function from test;

switch S1;
create function test2 () begin end;

# still possible
drop function test;
switch S0;
grant create_topic to test;

# test: create_subscription
switch S1;
create topic test;
create subscription test_sub on test;

switch S0;
revoke create_subscription from test;

switch S1;
create subscription test_sub2 on test;

# still possible
drop subscription test_sub;
drop topic test;
switch S0;

# test: create_user
switch S1;

# -- not allowed by default
create agent test2;

switch S0;
grant create_user to test;

switch S1;
create agent test2;

select parent, `name`, grants from show users verbose;
select parent, `name`, grants from show users verbose;

drop agent test2;
select parent, `name`, grants from show users verbose;

create agent test2;

# test: create_token
create token test;
create token test2;

switch S0;
grant create_token to test;

switch S1;
create token test;

# OK
# create token test2;
switch S0;
grant create_table to test;

# test: insert
switch S0;

# (not supported, must be per relation)
grant insert to test;

# amelie.test
create table test (id int primary key, data int);

switch S1;
show all rels;

insert into amelie.test values (123, 0);

# requires select
insert into amelie.test values (124, 0) returning *;

switch S0;
grant insert on test to test;

switch S1;
show all rels;

insert into amelie.test values (123, 0);
select * from amelie.test;
switch S0;

# test: select

# (not supported, must be per relation)
grant select to test;
grant select on test to test;

switch S1;
select * from amelie.test;
insert into amelie.test values (124, 0) returning *;
select * from amelie.test;
switch S0;

# test: update
switch S1;
update amelie.test set data = 1;

switch S0;
grant update to test;
grant update on test to test;

switch S1;
update amelie.test set data = 1;
select * from amelie.test;

update amelie.test set data = 1 returning *;
select * from amelie.test;
switch S0;

# test: delete
switch S1;
delete from amelie.test where id = 123;

switch S0;
grant delete to test;
grant delete on test to test;

switch S1;
delete from amelie.test where id = 123 returning *;
select * from amelie.test;
switch S0;

# test: publish
create topic top;
grant publish into test;

switch S1;
show all rels;
publish into amelie.top 123;

switch S0;
grant publish on top to test;

switch S1;
show all rels;
publish into amelie.top 123;
switch S0;

# test: execute
create function fun () return int
begin
  return 123;
end;

switch S1;
show all rels;
select amelie.fun();
execute amelie.fun();
post /api application/json - {"jsonrpc": "2.0", "id": 11, "method": "amelie/write", "params": {"rel": "fun", "args": []}};
post /api application/json - {"jsonrpc": "2.0", "id": 11, "method": "amelie/write", "params": {"user": "amelie", "rel": "fun", "args": []}};

switch S0;
grant execute on fun to test;

switch S1;
show all rels;
select amelie.fun();
execute amelie.fun();
post /api application/json - {"jsonrpc": "2.0", "id": 11, "method": "amelie/write", "params": {"user": "amelie", "rel": "fun", "args": []}};
switch S0;

# test: grant
revoke grant from test;

switch S1;
create table test (id int primary key);
grant select on test to amelie;

switch S0;

# test: system
switch S1;
checkpoint;

switch S0;
grant system to test;

switch S1;
checkpoint;

switch S0;

# test: sql
revoke sql from test;

switch S1;

select 1;
post /api application/json - {"jsonrpc": "2.0", "id": 11, "method": "amelie/sql", "params": {"text": "select 1"}};
switch S0;

# test: api
grant sql to test;
revoke api from test;

switch S1;

select 1;
post /api application/json - {"jsonrpc": "2.0", "id": 11, "method": "amelie/sql", "params": {"text": "select 1"}};
switch S0;

# test: user drop revoke
drop user test2 cascade;
create user test2;

connect E0 S2 test2@127.0.0.1:3485;

switch S2;
create table test (id int primary key);
grant select on test to test;
show rels;
show grants on test;

switch S1;
select * from test2.test;

switch S0;
drop user test cascade;

switch S2;
select current_user;

# <<
show grants on test;
select * from test;
show rels;

switch S0;

disconnect S1;
disconnect S2;

# test: user rename grant
drop user test2 cascade;

create user test;
create user test2;

connect E0 S1 test@127.0.0.1:3485;
connect E0 S2 test2@127.0.0.1:3485;

switch S2;
create table test (id int primary key);
grant select on test to test;
show rels;
show grants on test;

switch S1;
select * from test2.test;

switch S0;
alter user test rename to test_renamed;
disconnect S1;
connect E0 S1 test_renamed@127.0.0.1:3485;
select * from test2.test;

switch S2;
show grants on test;

switch S0;

disconnect S1;
disconnect S2;

# test: execute (after replace)
drop function fun cascade;

create user u;

create function fun () return int
begin
  return 1;
end;

grant execute on fun to u;
show grants on fun;

create or replace function fun () return int
begin
  return 2;
end;
show grants on fun;

connect E0 S1 u@127.0.0.1:3485;
switch S1;
execute amelie.fun();

switch S0;
revoke execute on fun from u;
grant execute on fun to u;

switch S1;
execute amelie.fun();

disconnect S1;

switch S0;
show grants on fun;
drop user u;
show grants on fun;

# test: select (from subscription)
create user u;
create table t (id int primary key, data int);
create subscription t_sub on t;
insert into t values (1, 10), (2, 20);

connect E0 S1 u@127.0.0.1:3485;
switch S1;

select * from amelie.t;
explain select * from amelie.t_sub;
select * from amelie.t_sub;

switch S0;
disconnect S1;

drop subscription t_sub;
drop table t;
drop user u cascade;

# test: revoke
create user u1;
create user u2;
create user u3;

create table t (id int primary key);
insert into t values (1);
grant select on t to u1;
grant select on t to u2;
grant select on t to u3;
show grants on t;

revoke select on t from u1;
show grants on t;

grant select on t to u1;
show grants on t;

revoke select on t from u3;
show grants on t;

revoke select on t from u2;
show grants on t;

revoke select on t from u1;
show grants on t;

grant select on t to u1;
grant select on t to u2;
grant select on t to u3;
show grants on t;
drop table t;

# test: returning (select)
create user u;
create table secrets (id int primary key, secret text);
insert into secrets values (1, "top-secret");
grant insert on secrets to u;
grant update on secrets to u;

connect E0 S1 u@127.0.0.1:3485;
switch S1;
select * from amelie.secrets;
insert into amelie.secrets values (1, "ignored") on conflict do update set secret = secret returning *;
insert into amelie.secrets values (1, "ignored") on conflict do nothing returning *;
insert into amelie.secrets values (1, "ignored") returning *;

switch S0;
drop user u;
drop table secrets;
disconnect S1;

disconnect S0;
close E0;
