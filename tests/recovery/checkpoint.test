# test: truncate
drop table test cascade;

create table test (id int primary key);
insert into test values (1), (2);
select * from test;

truncate test;
select * from test;

# test: checkpoint and restart
checkpoint;
disconnect S0;
close E0;
open E0;
connect E0 S0 127.0.0.1:3485;
select * from test;

# test: truncate (after restart)
insert into test values (1), (2);
select * from test;

# test: checkpoint and restart
checkpoint;
disconnect S0;
close E0;
open E0;
connect E0 S0 127.0.0.1:3485;

select * from test;
truncate test;
select * from test;

# test: drop column
drop table test cascade;

create table test (id int primary key, old_col text, keep_col int);
insert into test values (1, 'gone', 10), (2, 'gone2', 20);

select show('state').checkpoint;

alter table test drop column old_col;

select show('table', 'test', true).columns;
select old_col from test order by id;

# test: checkpoint and restart
checkpoint;

disconnect S0;
close E0;
open E0;
connect E0 S0 127.0.0.1:3485;

select show('state').checkpoint;

select show('table', 'test', true).columns;
select old_col from test order by id;
select * from test order by id;
drop table test;

# test: subscription (multi-row)
create table test (id int primary key, data int);
create subscription test_sub on test;
insert into test values (1, 10), (2, 20), (3, 30);
select * from test_sub;

# test: checkpoint and restart
checkpoint;
disconnect S0;
close E0;
open E0;
connect E0 S0 127.0.0.1:3485;

select * from test_sub;
select * from test order by id;
drop subscription test_sub;
drop table test;

# test: subscription (ack)
create table test (id int primary key, data int);
create subscription test_sub on test;
insert into test values (1, 10), (2, 20), (3, 30);
acknowledge test_sub to 34, 0;
select * from test_sub;

# test: checkpoint and restart
checkpoint;
select * from test_sub;

disconnect S0;
close E0;
open E0;
connect E0 S0 127.0.0.1:3485;

select lsn, lsn_op from show subscriptions verbose;
select * from test_sub;
select * from test order by id;
drop table test;
drop table test cascade;

# test: subscription (drop source)
create table test (id int primary key);
create subscription test_sub on test;
# error
drop table test;
drop table test cascade;
checkpoint;

disconnect S0;
close E0;
open E0;
connect E0 S0 127.0.0.1:3485;

show subs;
show tables;

# test: subscription (source alter)
create table test (id int primary key, data int);
create subscription test_sub on test;
insert into test values (1, 10);
select * from test_sub;

# error
alter table test rename column data to data_new;
select * from test_sub;
checkpoint;

disconnect S0;
close E0;
open E0;
connect E0 S0 127.0.0.1:3485;

select * from test_sub;
select * from test order by id;
drop table test cascade;

# test: subscription (post checkpoint cdc)
create table test (id int primary key, data int);
create subscription test_sub on test;
checkpoint;
insert into test values (1, 0);
insert into test values (2, 0);
select * from test_sub;

disconnect S0;
close E0;
open E0;
connect E0 S0 127.0.0.1:3485;

select * from test;
# replied once
select * from test_sub;
drop table test cascade;

# test: subscription (clone)
create table main (id int primary key, data int) partitions 1;
create clone a of main;
create clone b of main;
create subscription sub_a on a;
create subscription sub_b on b;
begin;
insert into a values (1, 10);
insert into b values (2, 20);
end;
select * from sub_a;
select * from sub_b;

# test: restart/recover (wal)
disconnect S0;
close E0;
open E0;
connect E0 S0 127.0.0.1:3485;

select * from sub_a;
select * from sub_b;
select * from a order by id;
select * from b order by id;

# test: restart/recover (checkpoint)
checkpoint;

disconnect S0;
close E0;
open E0;
connect E0 S0 127.0.0.1:3485;

select * from sub_a;
select * from sub_b;
select * from a order by id;
select * from b order by id;
drop table main cascade;

disconnect S0;
close E0;
