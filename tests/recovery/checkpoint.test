# test: create function
create function reverse(array json) return json
begin
	declare rev json := [];
	for it in (array) do
		rev := rev::push(it);
	end;
	return rev;
end;
show functions verbose;
select [1,2,3]::reverse;

# test: restart/recover (checkpoint + wal)
disconnect S0;
close E0;
