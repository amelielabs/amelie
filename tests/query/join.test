#
open E0 "uuid": "00000000-0000-0000-0000-000000000000", "listen": [{ "host": "127.0.0.1", "port": 3485 }];
connect E0 S0 127.0.0.1:3485;

# test: cross join (tree)
create table a (id int primary key) partitions 1;
create table b (id int primary key) partitions 3;
insert into a values (0);
insert into b values (0), (4), (2);
select count(*) from a, b;
explain select b.id from a, b order by b.id;
select b.id from a, b order by b.id;
select * from b order by id;
drop table a;
drop table b;

# test: cross join (hash)
create table a (id int primary key) partitions 1;
create table b (id int primary key using hash) partitions 3;
insert into a values (0);
insert into b values (0), (4), (2);
select count(*) from a, b;
explain select b.id from a, b order by b.id;
select b.id from a, b order by b.id;
select * from b order by id;
drop table a;
drop table b;

# 1 partition
create table a (id int primary key) partitions 1;
create table b (id int primary key using hash) partitions 1;
insert into a values (0);
insert into b values (0), (4), (2);
select count(*) from a, b;
explain select b.id from a, b order by b.id;
select b.id from a, b order by b.id;
select * from b order by id;
drop table a;
drop table b;

disconnect S0;
close E0;
