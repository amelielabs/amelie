#
open E0 "uuid": "00000000-0000-0000-0000-000000000001", "listen": [{ "host": "127.0.0.1", "port": 3485 }];
connect E0 S0 127.0.0.1:3485;

# test: create subscription statement parsing
create subscription;
create subscription x;
create subscription x 123;
create subscription x on;
create subscription x on 123;

# test: create subscription (table)
create table test (id int primary key, data int);
create subscription test_sub on test description 'test test';
show subs;
show subscriptions;
select lsn, lsn_op from show subscriptions verbose;

# test: create subscription (table, if exists)
create subscription test_sub on test;
create subscription if not exists test_sub on test;

# test: select from subscription (empty)
select * from test_sub;

# test: cdc (insert)
insert into test values (1, 0);
insert into test values (2, 0);
insert into test values (3, 0);

# test: select from subscription
select * from test_sub;

# test: cdc (batch insert)
insert into test values (4, 0), (5, 0), (6, 0);

# test: select from subscription
select * from test_sub;
select count(*) from test_sub;
select lsn, count(*) from test_sub group by lsn;

# test: cdc (delete)
delete from test where id = 1;

# test: select from subscription
select * from test_sub;

# test: cdc (batch delete)
delete from test where id <= 3;

# test: select from subscription
select * from test_sub;

# test: cdc (update)
update test set data = 1 where id = 4;

# test: select from subscription
select * from test_sub;

# test: cdc (batch update)
update test set data = 2;

# test: select from subscription
select * from test_sub;

# test: acknowledge
select lsn, lsn_op from show subscriptions verbose;

acknowledge;
acknowledge 123;
acknowledge test_sub;
acknowledge test_sub to;

acknowledge test_sub to 3;
select lsn, lsn_op from show subscriptions verbose;
select * from test_sub;

acknowledge test_sub to 3, 10;
select lsn, lsn_op from show subscriptions verbose;
select * from test_sub;

acknowledge test_sub to 4;
select lsn, lsn_op from show subscriptions verbose;
select * from test_sub;

acknowledge test_sub to 7, 0;
select lsn, lsn_op from show subscriptions verbose;
select * from test_sub;

acknowledge test_sub to 7, 1;
select lsn, lsn_op from show subscriptions verbose;
select * from test_sub;

acknowledge test_sub to 7, 2;
select lsn, lsn_op from show subscriptions verbose;
select * from test_sub;

acknowledge test_sub to 7, 3;
select lsn, lsn_op from show subscriptions verbose;
select * from test_sub;

acknowledge test_sub to 7, 4;
select lsn, lsn_op from show subscriptions verbose;
select * from test_sub;

acknowledge test_sub to 11, 1;
select lsn, lsn_op from show subscriptions verbose;
select * from test_sub;

# test: acknowledge (same value)
acknowledge test_sub to 11, 1;

# test: acknowledge (downgrade)
acknowledge test_sub to 7, 4;

# test: acknowledge (abort)
begin
  acknowledge test_sub to 11, 2;
  select error("abort");
end;
select lsn, lsn_op from show subscriptions verbose;

# test: drop table (cascade)
drop table test;
drop table test cascade;
show tables;

# test: drop subscription statement parsing
drop subscription;
drop subscription 123;

# test: drop subscription (if exists)
drop subscription test_sub;
drop subscription if exists test_sub;

# test: create subscription (topic)
create topic test;
create subscription test_sub on test;
show subs;
show subscriptions;
select lsn, lsn_op from show subscriptions verbose;

# test: cdc (publish)
publish into test;
publish into test 123;
publish into test 1,2,3;

# test: select from subscription
select * from test_sub;

# test: acknowledge
acknowledge test_sub to 26;
select lsn, lsn_op from show subscriptions verbose;
select * from test_sub;

acknowledge test_sub to 27, 1;
select lsn, lsn_op from show subscriptions verbose;
select * from test_sub;

# test: drop topic
drop topic test;
show subs;

# test: drop topic (cascade)
drop topic test cascade;
show subs;

# test: create subscription (clone)
create table test (id int primary key);
create subscription test_sub on test;

create clone test_clone of test;
create subscription test_clone_sub on test_clone;

select lsn, lsn_op from show subscriptions verbose;

insert into test values (123);
insert into test_clone values (1), (2), (3);

select * from test_sub;
select * from test_clone_sub;

drop subscription test_sub;
drop subscription test_clone_sub;
drop table test cascade;

# test: create subscription (clone only)
create table test (id int primary key);
create clone test_clone of test;
create subscription test_clone_sub on test_clone;

insert into test_clone values (1), (2), (3);
select * from test_clone_sub;
select * from test_clone;

drop subscription test_clone_sub;
drop table test cascade;

# test: create subscription (clone, parent drop)
create table test (id int primary key);
create clone test_clone of test;
create subscription base_sub on test;
create subscription clone_sub on test_clone;

insert into test_clone values (1);
select * from clone_sub;

drop subscription base_sub;
insert into test_clone values (2);

select * from clone_sub;
select * from test_clone order by id;

drop subscription clone_sub;
drop table test cascade;

# test: alter subscription statement parsing
create topic test;
create subscription test_sub on test;

alter subscription;
alter subscription 123;
alter subscription test;
alter subscription test rename;
alter subscription test rename to;

# test: alter subscription rename to
alter subscription test_sub rename to test_cdc;
show subs;

# test: alter subscription rename to (if exists)
alter subscription test_sub rename to test_cdc;
alter subscription if exists test_sub rename to test_cdc;

drop subscription test_cdc;
drop topic test;

# test: alter subscription description
create table test (id int primary key);
create subscription x on test;
alter subscription x description 'test test';
show subscription x;
drop table test cascade;
show subs;

# test: select from subscription (multiple rels)
create table a (id int primary key, data int);
create table b (id int primary key, data int);
create subscription a_sub on a;
create subscription b_sub on b;
insert into b values (42, 900);
select * from a_sub;
select * from b_sub;

drop subscription a_sub;
drop subscription b_sub;
drop table a;
drop table b;

# test: create subscription (overflow)
create table test (id int primary key, data string);
create subscription test_sub on test;
begin
  declare i int := 0;
  declare s string := "";
  while i < 6000 do
    s := concat(s, "xxxxxxxxxx");
    i := i + 1;
  end;
  insert into test values (1, s);
  insert into test values (2, s);
  insert into test values (3, s);
  insert into test values (4, s);
  insert into test values (5, s);
  insert into test values (6, s);
  insert into test values (7, s);
  insert into test values (8, s);
end;

select lsn, lsn_op from test_sub order by lsn_op;
acknowledge test_sub to 74, 0;
select lsn, lsn_op from test_sub order by lsn_op;
select count(*) from test_sub;
select count(*) from test;

drop subscription test_sub;
drop table test;

# test: create subscription (table dep)
create table test (id int primary key, data string);
create subscription test_sub on test;
# errors
alter table test rename column data to data2;
alter table test rename to test2;
drop table test cascade;

# test: create subscription (topic dep)
create topic test;
create subscription test_sub on test;
# error
alter topic test rename to test2;
drop topic test cascade;
show subs;

# test: create subscription (start after single stmt)
create table test (id int primary key, data int);
create subscription sub1 on test;
insert into test values (1, 0);
create subscription sub2 on test;
select lsn from show state;
select name, lsn, lsn_op  from show subs verbose;
select * from sub1;
select * from sub2;
drop table test cascade;

# test: create subscription (start after multi-stmt)
create table test (id int primary key, data int);
create subscription sub1 on test;
insert into test values (1, 0), (2, 0), (3, 0);
create subscription sub2 on test;
select lsn from show state;
select name, lsn, lsn_op  from show subs verbose;

select * from sub1;
select * from sub2;
drop table test cascade;

# test: acknowledge (lsn_op out-of-bounds check)
create table test (id int primary key, data int);
create subscription test_sub on test;
insert into test values (1, 0), (2, 0), (3, 0);
select * from test_sub;
select lsn, lsn_op from test_sub;
acknowledge test_sub to 96, 99;
select lsn, lsn_op from show subscriptions verbose;
select * from test_sub;
drop table test cascade;

# test: acknowledge (lsn_op rewind)
create topic t;
create subscription s on t;
publish into t 1,2,3;
select * from s;
acknowledge s to 101, 2;
select * from s;
acknowledge s to 101, 0;
select lsn, lsn_op from show subscriptions verbose;
select * from s;
drop topic t cascade;

# test: create subscription (with dropped column)
create table t (id int primary key, secret text, visible text);
insert into t values (1, "top-secret", "old");
alter table t drop column secret;
create subscription t_sub on t;
update t set visible = "new" where id = 1;
select * from t;
select row from t_sub;
drop table t cascade;

disconnect S0;
close E0;
