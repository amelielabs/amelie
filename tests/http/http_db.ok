open E0 "uuid": "00000000-0000-0000-0000-000000000000", "listen": [{ "host": "127.0.0.1", "port": 3485 }];
connect E0 S0 127.0.0.1:3485;
# test: POST uri parsing
post / - - -;
400 Bad Request
post /db - - -;
400 Bad Request
post /v1 - - -;
400 Bad Request
post /v1/ - - -;
400 Bad Request
post /v1/ - - -;
400 Bad Request
post /v1/d - - -;
400 Bad Request
# test: POST /v1/db
post /v1/db - - -;
{"msg": "unsupported operation content-type"}
post /v1/db/ - - -;
{"msg": "unsupported operation content-type"}
# test: POST /v1/db (invalid content type)
post /v1/db - - -;
{"msg": "unsupported operation content-type"}
post /v1/db json - -;
{"msg": "unsupported operation content-type"}
post /v1/db/ application/json - -;
{"msg": "unsupported operation content-type"}
# test: POST /v1/db (plain/text, no accept, no content)
post /v1/db plain/text - -;
# test: POST /v1/db (plain/text, no accept)
post /v1/db plain/text - select 1;
[1]
# test: POST /v1/db (plain/text, invalid accept)
post /v1/db plain/text xyz select 1;
400 Bad Request
# test: POST /v1/db (plain/text)
post /v1/db plain/text application/json select 1;
[1]
# test: POST /v1/db?args parsing
post /v1/db? plain/text application/json select 1;
400 Bad Request
post /v1/db?a plain/text application/json select 1;
400 Bad Request
post /v1/db?format plain/text application/json select 1;
400 Bad Request
# test: POST /v1/db?format
post /v1/db/?format= plain/text application/json select 1;
[1]
post /v1/db/?format=full plain/text application/json select 1;
[{"col1": 1}]
post /v1/db/?format=full-pretty plain/text - select 1;
[{
  "col1": 1
}]
post /v1/db/?format=full-pretty plain/text - show tables;
{
  "result": []
}
disconnect S0;
close E0;
