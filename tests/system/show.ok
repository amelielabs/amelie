# test: show functions
create function test_fn (id int) return json
begin
	return {
		"a": 2 + 2,
		"b": id
	};
end;
select test_fn(123);

test_fn
───────
{
  "a": 4,
  "b": 123
}
select test_fn(123).a;

a
─
4
select 123::test_fn().a;

a
─
4
