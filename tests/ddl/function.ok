error: alter❰;❱ ⟵ relation type expected
alter function;
error: alter function❰;❱ ⟵ name expected
alter function 123;
error: alter function ❰123❱ ⟵ name expected
alter function if;
error: alter function if❰;❱ ⟵ EXISTS expected
alter function if exists;
