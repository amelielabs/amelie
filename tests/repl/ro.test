#

open E0 "uuid": "00000000-0000-0000-0000-000000000000", "listen": [{ "host": "127.0.0.1", "port": 3480 }], "backends": 3, "repl_reconnect_ms": 10;
connect E0 S0 127.0.0.1:3480;

# test: read-only ddl
start repl;
subscribe "00000000-0000-0000-0000-000000000001";
select show("state").read_only;
select show("state").psn;
create table leaked (id int primary key);
select show("state").psn;
show tables;
select * from leaked;

# test: read-only publish
unsubscribe;
stop repl;

create topic t;
create subscription t_sub on t;

start repl;
subscribe "00000000-0000-0000-0000-000000000001";
select show("state").read_only;
select show("state").lsn;
publish into t 123;
select show("state").lsn;
select * from t_sub;

disconnect S0;
close E0;
