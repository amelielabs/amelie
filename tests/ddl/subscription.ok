# test: create subscription (overflow)
create table test (id int primary key, data string);
create subscription test_sub on test;
begin
  declare i int := 0;
  declare s string := "";
  while i < 6000 do
    s := concat(s, "xxxxxxxxxx");
    i := i + 1;
  end;
  insert into test values (1, s);
  insert into test values (2, s);
  insert into test values (3, s);
  insert into test values (4, s);
  insert into test values (5, s);
  insert into test values (6, s);
  insert into test values (7, s);
  insert into test values (8, s);
end;
select lsn, lsn_op from test_sub order by lsn_op;

