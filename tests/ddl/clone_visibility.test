#

open E0 "uuid": "00000000-0000-0000-0000-000000000001", "listen": [{ "host": "127.0.0.1", "port": 3485 }];
connect E0 S0 127.0.0.1:3485;

# test: clone
create table main (id int primary key, data int);
insert into main values (1, 0);

create clone a of main;

# test: clone (parent unique violation)
insert into a values (1, 1);

# test: clone (unique violation)
insert into a values (2, 1);
insert into a values (2, 1);
insert into a values (3, 1);

select * from a;
select * from main;

# test: clone (delete parent)
delete from a where id = 1;
select * from a;
select * from main;

# test: clone (delete)
delete from a where id = 3;

select * from a;
select * from main;

# test: clone (insert after update parent)
insert into a values (1, 1);
select * from a;
select * from main;

# test: clone (update parent)
update a set data = 11 where id = 1;
select * from a;
select * from main;

drop table main cascade;

# test: clone (main -> a, b)
create table main (id int primary key, data int);
insert into main values (1, 0);

create clone a of main;
update a set data = 1;
insert into a values (2, 1);

create clone b of main;
update b set data = 2;
insert into b values (2, 2);

select * from a;
select * from b;
select * from main;

# test: clone (delete from b)
delete from b where id = 1;

select * from b;

# test: clone (key)
select * from main where id >= 0;
select * from main where id = 0;
select * from main where id >= 1;
select * from main where id = 1;
select * from main where id >= 2;
select * from main where id = 2;
select * from main where id >= 3;
select * from main where id = 3;

select * from a where id >= 0;
select * from a where id = 0;
select * from a where id >= 1;
select * from a where id = 1;
select * from a where id >= 2;
select * from a where id = 2;
select * from a where id >= 3;
select * from a where id = 3;

select * from b where id >= 0;
select * from b where id = 0;
select * from b where id >= 1;
select * from b where id = 1;
select * from b where id >= 2;
select * from b where id = 2;
select * from b where id >= 3;
select * from b where id = 3;

# test: clone (select after drop)
drop clone b;
show clones;
select * from a;
select * from main;

drop clone a;
show clones;
select * from main;

drop table main cascade;

# test: clone (empty main -> a, b)
create table main (id int primary key, data int);

create clone a of main;
insert into a values (1, 1);
insert into a values (2, 1);

create clone b of main;
insert into b values (1, 2);
insert into b values (2, 2);

select * from a;
select * from b;

# test: clone (aba)
select snapshot from show clones verbose;
drop clone b;

create clone b of main;
select snapshot from show clones verbose;

select * from a;
select * from b;

insert into b values (1, 3);
insert into b values (2, 3);

select * from a;
select * from b;

drop table main cascade;

disconnect S0;
close E0;
