#

open E0 "uuid": "00000000-0000-0000-0000-000000000000", "listen": [{ "host": "127.0.0.1", "port": 3485 }];
connect E0 S0 127.0.0.1:3485;

create table test (id int primary key, a int, b int);
create table test2 (id int primary key, a int as (id * 2) stored);
create table test3 (id int primary key, a int as (a + 1) resolved);
create table test4 (id serial primary key, a int default 777);
create table test5 (id serial primary key, data json not null);
create table test6 (id int primary key as (data.id::int) stored, data json not null);

# test: POST /v1/import (relation is missing)
post /v1/import plain/text - 123;

# test: POST /v1/import (relation not exists)
post /v1/import?relation=xyz plain/text - 123;

## test: POST /v1/import (type is missing)
post /v1/import?relation=test plain/text - 123;

## test: POST /v1/import (type unsupported)
post /v1/import?relation=test&type=xyz plain/text - 123;

# test: POST /v1/import (csv)
post /v1/import?relation=test&type=csv - - 0,0,0;
post /v1/import?relation=test&type=csv - - 1,0,0;
post /v1/import?relation=test&type=csv - - 2,0,0;
select * from test;

# test: POST /v1/import (csv, columns)
post /v1/import?relation=test&type=csv&columns=id - - 3;
post /v1/import?relation=test&type=csv&columns=id - - 4;
post /v1/import?relation=test&type=csv&columns=id - - 5;
select * from test;

post /v1/import?relation=test&type=csv&columns=id,a - - 6,0;
post /v1/import?relation=test&type=csv&columns=id,a,b - - 7,0,0;
select * from test;

# test: POST /v1/import (csv, column list dups)
post /v1/import?relation=test&type=csv&columns=id,a,a - - 8,0,0;

# test: POST /v1/import (csv, column list unordered)
post /v1/import?relation=test&type=csv&columns=id,b,a - - 8,0,0;

# test: POST /v1/import (csv, column list empty)
post /v1/import?relation=test4&type=csv&columns= - - -;

# test: POST /v1/import (csv, generated columns)
post /v1/import?relation=test2&type=csv - - 0,null;
post /v1/import?relation=test2&type=csv - - 1,null;
post /v1/import?relation=test2&type=csv - - 2,null;
select * from test2;

# test: POST /v1/import (csv, resolved columns)
post /v1/import?relation=test3&type=csv - - 0,0;
post /v1/import?relation=test3&type=csv - - 0,0;
post /v1/import?relation=test3&type=csv - - 0,0;
post /v1/import?relation=test3&type=csv - - 1,0;
post /v1/import?relation=test3&type=csv - - 1,0;
post /v1/import?relation=test3&type=csv - - 1,0;
select * from test3;

# test: POST /v1/import (jsonl, not null)
post /v1/import?relation=test5&type=jsonl - - {"id": 1} {"id": 2} {"id": 3};

# test: POST /v1/import (jsonl, default)
post /v1/import?relation=test5&type=jsonl - - {"data": 0} {"data": 0} {"data": 0};
select * from test5;

# test: POST /v1/import (jsonl)
post /v1/import?relation=test5&type=jsonl - - {"id": 3, "data": 0} {"id": 4, "data": 0} {"id": 5, "data": 0};
select * from test5;

# test: POST /v1/import (jsonl)
post /v1/import?relation=test&type=jsonl - - {"id": 20};
post /v1/import?relation=test&type=jsonl - - {"id": 20, "a";
post /v1/import?relation=test&type=jsonl - - {"id": 20,;
post /v1/import?relation=test&type=jsonl - - {"id": 20, 1;
post /v1/import?relation=test&type=jsonl - - {"id": 20, "a";
post /v1/import?relation=test&type=jsonl - - {"id": 20, "a":;
post /v1/import?relation=test&type=jsonl - - {"id": 20, "a": 0;
post /v1/import?relation=test&type=jsonl - - {"id": 20, "a": 0,;
post /v1/import?relation=test&type=jsonl - - {"id": 20, "a": 0, "b";
post /v1/import?relation=test&type=jsonl - - {"id": 20, "a": 0, "b": 0};
post /v1/import?relation=test&type=jsonl - - {"id": 21, "a": 0, "b": 0};
post /v1/import?relation=test&type=jsonl - - {"id": 22, "b": 0};
post /v1/import?relation=test&type=jsonl - - {"id": 23};
post /v1/import?relation=test&type=jsonl - - {"id": 22, "b": 0, "b": 1};
post /v1/import?relation=test&type=jsonl - - {"id": 24} {"id": 25} {"id": 26};
select * from test;

# test: POST /v1/import (json)
post /v1/import?relation=test&type=json - - [{"id": 27}, {"id": 28}];
select * from test;

# test: POST /v1/import (json)
post /v1/import?relation=test5&type=json - - [{"id": 4}, {"id": 5}];

post /v1/import?relation=test5&type=json - - [{"id": 40, "data": 77}, {"id": 50, "data": 77}];
select * from test5;

# test: POST /v1/import (json, generated)
post /v1/import?relation=test6&type=json - - [{"id": 2, "data": {"id": 55}}];
select * from test6;

# test: POST /v1/import (csv, function)
create function test_fn(a int, b int, c int) return int
begin
	return a + b + c;
end;
post /v1/import?relation=test_fn&type=csv - - 1,2,3;

# test: POST /v1/import (csv, function, column list)
post /v1/import?relation=test_fn&type=csv&columns=a - - 1,2,3;
post /v1/import?relation=test_fn&type=csv&columns=a - - 4;

# test: POST /v1/import (json, function, empty)
post /v1/import?relation=test_fn&type=json - - {};

# test: POST /v1/import (json, function)
post /v1/import?relation=test_fn&type=json - - {"a": 1, "b": 2, "c": 3};

# test: POST /v1/import (jsonl, function)
post /v1/import?relation=test_fn&type=jsonl - - {"a": 1, "b": 2, "c": 3};

disconnect S0;
close E0;
