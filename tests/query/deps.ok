# test: while select from into / if if continue
explain begin
	declare i int := 0;
	declare x int;

	while true do
		if i = 3 then
			break;
		end;
		i := i + 1;
		select id into x from test;
		if true then
			if true then
				continue;
			end;
		end;
		x := null;
	end;
	select i, x;
end;

