open E0 "uuid": "00000000-0000-0000-0000-000000000000", "listen": [{ "host": "127.0.0.1", "port": 3480 }], "backends": 3, "repl_reconnect_ms": 10;
connect E0 S0 127.0.0.1:3480;
# test: backup replica
backup E1 http://127.0.0.1:3480;
close E1;
open E1 "uuid": "00000000-0000-0000-0000-000000000001", "listen": [{ "host": "127.0.0.1", "port": 3481 }];
connect E1 S1 127.0.0.1:3481;
switch S1;
start repl;
subscribe "00000000-0000-0000-0000-000000000000";
# test: create replica
switch S0;
create replica "00000000-0000-0000-0000-000000000001" "127.0.0.1:3481";
start repl;
watch show("replica", "00000000-0000-0000-0000-000000000001").connected::bool = true;
# test: create unlogged table
create unlogged table u (id int primary key, v int);
insert into u values (1, 10), (2, 20);
select * from u order by id;

id  v
────────
1   10
2   20
# test: sync
watch show("replica", "00000000-0000-0000-0000-000000000001").lsn = show("state").lsn;
switch S1;
select show("state").lsn;

lsn
───
2
select * from u order by id;

id  v
───────
switch S0;
disconnect S0;
disconnect S1;
close E0;
close E1;
