# test: prepare server
open E0 "uuid": "00000000-0000-0000-0000-000000000000", "listen": [{ "host": "127.0.0.1", "port": 3480, "tls": true, "tls_cert": "./tls/server.crt", "tls_key": "./tls/server.key" }], "backends": 3;
connect E0 S0 https://127.0.0.1:3480 ./tls/ca.crt;
create table test (id serial primary key);
insert into test generate 500;
show state;

state
─────
{
  "version": "1.0.0-rc1",
  "directory": "./_output/E0",
  "uuid": "00000000-0000-0000-0000-000000000000",
  "frontends": 1,
  "backends": 3,
  "lsn": 3,
  "tsn": 2,
  "psn": 3,
  "checkpoint": 1
}
# test: backup (using https)
backup E1 https://127.0.0.1:3480;
close E1;
# test: shutdown previous server
disconnect S0;
close E0;
# test: restore and validate
open E1;
connect E1 S1 https://127.0.0.1:3480 ./tls/ca.crt;
show all;

