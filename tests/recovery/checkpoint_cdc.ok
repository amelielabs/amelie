open E0 "uuid": "00000000-0000-0000-0000-000000000000", "listen": [{ "host": "127.0.0.1", "port": 3485 }], "backends": 3;
connect E0 S0 127.0.0.1:3485;
# test: create topic (with subscription)
create topic top;
show topics;

topics
──────
{
  "user": "amelie",
  "name": "top",
  "description": ""
}
create subscription top_sub on top;
show subs;

subs
────
{
  "user": "amelie",
  "name": "top_sub",
  "description": ""
}
publish into top 123;
publish into top 1,2,3;
publish into top;
select * from top_sub;

lsn  lsn_op  cmd      row
────────────────────────────
4    0       publish  123
5    0       publish  1
5    1       publish  2
5    2       publish  3
6    0       publish  null
# test: checkpoint/restart
checkpoint;
# test: restart/recover
disconnect S0;
close E0;
open E0;
connect E0 S0 127.0.0.1:3485;
select * from top_sub;

lsn  lsn_op  cmd      row
────────────────────────────
4    0       publish  123
5    0       publish  1
5    1       publish  2
5    2       publish  3
6    0       publish  null
# test: create table (with subscription)
create table test (id int primary key, data int);
create subscription test_sub on test;
insert into test values (1, 10), (2, 20), (3, 30);
select * from test_sub;

lsn  lsn_op  cmd    row
───────────────────────────────────────────
9    0       write  {"id": 1, "data": 10}
9    1       write  {"id": 2, "data": 20}
9    2       write  {"id": 3, "data": 30}
# test: checkpoint/restart
checkpoint;
# test: restart/recover
disconnect S0;
close E0;
open E0;
connect E0 S0 127.0.0.1:3485;
select * from test_sub;

lsn  lsn_op  cmd    row
───────────────────────────────────────────
9    0       write  {"id": 1, "data": 10}
9    1       write  {"id": 2, "data": 20}
9    2       write  {"id": 3, "data": 30}
select * from top_sub;

lsn  lsn_op  cmd      row
────────────────────────────
4    0       publish  123
5    0       publish  1
5    1       publish  2
5    2       publish  3
6    0       publish  null
drop topic top cascade;
drop table test cascade;
disconnect S0;
close E0;
