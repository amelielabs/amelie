open E0 "uuid": "00000000-0000-0000-0000-000000000000", "listen": [{ "host": "127.0.0.1", "port": 3485 }];
connect E0 S0 127.0.0.1:3485;
# test: POST /v1/rpc
post /v1/rpc - - -;
{"msg": "unsupported operation content-type"}
post /v1/rpc - - -;
{"msg": "unsupported operation content-type"}
# test: POST /v1/rpc (invalid content type)
post /v1/rpc - - -;
{"msg": "unsupported operation content-type"}
post /v1/rpc json - -;
{"msg": "unsupported operation content-type"}
# test: POST /v1/rpc (mandatory fields)
post /v1/rpc application/json - {"jsonrpc": "2.0"} ;
{"msg": "jsonrpc: invalid request"}
post /v1/rpc application/json - {"jsonrpc": "2.0", "id": 11};
{"msg": "jsonrpc: invalid request"}
post /v1/rpc application/json - {"jsonrpc": "2.0", "method": sql};
{"msg": "unexpected JSON token"}
# test: POST /v1/rpc (sql, no params)
post /v1/rpc application/json - {"jsonrpc": "2.0", "id": 11, "method": "sql"};
{"msg": "jsonrpc: sql 'params' are missing"}
# test: POST /v1/rpc (sql, params validatation)
post /v1/rpc application/json - {"jsonrpc": "2.0", "id": 11, "method": "sql", "params": 1};
{"msg": "jsonrpc: sql 'params' is not an object"}
post /v1/rpc application/json - {"jsonrpc": "2.0", "id": 11, "method": "sql", "params": []};
{"msg": "jsonrpc: sql 'params' is not an object"}
post /v1/rpc application/json - {"jsonrpc": "2.0", "id": 11, "method": "sql", "params": {}};
{"msg": "jsonrpc: sql 'text' is not defined"}
post /v1/rpc application/json - {"jsonrpc": "2.0", "id": 11, "method": "sql", "params": {"a": "b"}};
{"msg": "jsonrpc: unexpected params field"}
# test: POST /v1/rpc (sql)
post /v1/rpc application/json - {"jsonrpc": "2.0", "id": 11, "method": "sql", "params": {"text": "select 1"}};
{ "columns": ["col1"], "rows": [[1]] }
disconnect S0;
close E0;
