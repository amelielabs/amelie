#

open E0 "uuid": "00000000-0000-0000-0000-000000000000", "listen": [{ "host": "127.0.0.1", "port": 3485 }];
connect E0 S0 127.0.0.1:3485;

# test: create clone statement parsing
create clone;
create clone 123;
create clone 123 from;
create clone 123 of;
create clone 123 of 1;

# test: create clone
create table main (id int primary key);
insert into main values (1);

create clone a of main;
show clones;

drop clone a;
drop table main;

# test: create clone (insert)
create table main (id int primary key);
insert into main values (1);

create clone a of main;

# error
insert into a values (1);
insert into a values (2);

select * from a;
select * from main;

drop table main;
drop table main cascade;

# test: create clone (update)
create table main (id int primary key, data int);
insert into main values (1, 0);
insert into main values (2, 0);
insert into main values (3, 0);
insert into main values (4, 0);

create clone a of main;

update a set data = 42 where id in (1, 3);
select * from a;
select * from main;

# test: create clone (delete/insert)
delete from a where id < 4;

select * from a;
select * from main;

insert into a values (1, 2);
insert into a values (2, 2);
insert into a values (3, 2);

select * from a;
select * from main;

# test: alter clone statement parsing
alter clone;
alter clone 1;
alter clone b;
alter clone b xyz;
alter clone b rename;
alter clone b rename to;

# test: alter clone rename to
alter clone a rename to b;

select * from b;
select * from main;

# test: drop parent clone
drop clone b;
show clones;

# test: cascade (parent clone)
create clone b of main;
drop table main cascade;

# test: cascade (table)
create table main (id int primary key, data int);
insert into main values (1, 0);
insert into main values (2, 0);
insert into main values (3, 0);
insert into main values (4, 0);

create clone a of main;
create clone b of main;
show clones;

drop table main;
drop table main cascade;
show clones;

# test: cascade (table, udf)
create table main (id int primary key, data int);
create clone a of main;
create clone b of main;

create function f() return int
begin
   return select count(*) from main;
end;

drop table main;
drop table main cascade;
show clones;
show functions;

# test: truncate
create table main (id int primary key);
insert into main values (1), (2);
create clone a of main;

# not supported
truncate a;

select * from a;

# truncated clones
truncate main;
select * from a;

drop table main cascade;

disconnect S0;
close E0;
