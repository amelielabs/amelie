#

open E0 "uuid": "00000000-0000-0000-0000-000000000000", "listen": [{ "host": "127.0.0.1", "port": 3485 }];
connect E0 S0 127.0.0.1:3485;

# test: ensure system users exists
select show('users')[0].name;
select show('agents');

# test: create user statement parsing
create;
create user;
create user 123;
create user if;
create user if not;
create user if not 123;
create user if not exists;
create user test abc;

# test: create user
create user test;
select show('user', 'test').name;

# test: create user if not exists
create user test;
create user if not exists test;
select show('user', 'test').name;

# test: drop user statement parsing
drop user;
drop user 123;
drop user if;
drop user if exists;
drop user test abc;

# test: drop user
drop user test;
select show('user', 'test').name;

# test: drop user if exists
drop user test;
drop user if exists test;
select show('user', 'test').name;

# test: drop main user
drop user main;
select show('user', 'test').name;
select show('user', 'main').name;

# test: drop user cascade
create user test;
drop user test cascade;
select show('user', 'test').name;

# test: drop connected user
create user test;
select show('user', 'test').name;

connect E0 S1 test@127.0.0.1:3485;
switch S1;
drop user test;
select show('user', 'test').name;
select 1;

disconnect S1;
switch S0;
drop user test;

# test: drop user cascade (with relations)
create user test;
connect E0 S1 test@127.0.0.1:3485;
switch S1;

create table a(id int primary key);
create table b(id int primary key);
create function fn() begin select * from a; end;

disconnect S1;
switch S0;

drop user test;
drop user test cascade;
select 1;

show tables;
show functions;
select show('user', 'test').name;
select show('user', 'main').name;

# test: alter user statment parsing
alter user;
alter user 123;
alter user test;
alter user test rename;
alter user test rename to;
alter user test rename "hello";

# test: alter user rename
create user test;
select show('user', 'test').name;
select show('user', 'hello').name;

alter user test rename to test2;
select show('user', 'test').name;
select show('user', 'test2').name;
drop user test2;

# test: alter user main
alter user main rename to _public;
select show('user', 'main').name;

# test: alter user rename cascade (udf dep)
create user test;
connect E0 S1 test@127.0.0.1:3485;
switch S1;

create table a(id int primary key);
insert into a values (1), (2), (3);

create table b(id int primary key);
create function fn() return int
begin
	total int = 0;
	select count(*) into total from a;
	return total;
end;
select fn();

drop function fn;

# test: alter user rename cascade
switch S0;

alter user test rename to test2;
select 1;

switch S1;
disconnect S1;
connect E0 S1 test2@127.0.0.1:3485;
switch S1;

show tables;
show functions;
select show('user', 'main').name;
select show('user', 'test2').name;

disconnect S1;
switch S0;

show tables;
show functions;
select show('user', 'main').name;
select show('user', 'test2').name;

drop user test2;
drop user test2 cascade;

# test: create agent
create agent test;
select show('user', 'main').name;
select show('user', 'test').name;
select show('agents')[0].name;
drop agent test;

disconnect S0;
close E0;
