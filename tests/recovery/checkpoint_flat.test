#

open E0 "uuid": "00000000-0000-0000-0000-000000000001", "listen": [{ "host": "127.0.0.1", "port": 3485 }], "backends": 3;
connect E0 S0 127.0.0.1:3485;

# test: create table (with vector columns)
create table test_flat(id int primary key, v1 vector(2), data int, v2 vector(1));
insert into test_flat values (0, [0,0], null, [0]);
insert into test_flat values (1, [1,1], null, [1]);
insert into test_flat values (2, [2,2], null, [2]);
select * from test_flat;

# test: checkpoint
checkpoint;
select show('state').checkpoint;

# test: restart/recover
disconnect S0;
close E0;
open E0;
connect E0 S0 127.0.0.1:3485;
select show('state').checkpoint;
select * from test_flat;

# test: add column (vector)
alter table test_flat add column v3 vector(3);
insert into test_flat values (3, [3,3], null, [3], [1,2,3]);
select * from test_flat;

# test: checkpoint
checkpoint;
select show('state').checkpoint;

# test: restart/recover
disconnect S0;
close E0;
open E0;
connect E0 S0 127.0.0.1:3485;
select show('state').checkpoint;
select * from test_flat;

# test: drop column (vector)
alter table test_flat drop column v1;
select * from test_flat;

# test: checkpoint
checkpoint;
select show('state').checkpoint;

# test: restart/recover
disconnect S0;
close E0;
open E0;
connect E0 S0 127.0.0.1:3485;
select show('state').checkpoint;
select * from test_flat;

# test: delete/insert
delete from test_flat where id = 1;
select * from test_flat;

# will replace 1 in the flat store
insert into test_flat values (4, null, null, [4,4,4]);
select * from test_flat;
drop table test_flat;

# test: delete/insert
create table test(id int primary key, v1 vector(2));
insert into test values (0, [0,0]);
insert into test values (1, [1,1]);
delete from test where id = 1;
insert into test values (1, [2,2]);
select * from test;
drop table test;

disconnect S0;
close E0;
