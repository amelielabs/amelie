#

open E0 "uuid": "00000000-0000-0000-0000-000000000001", "listen": [{ "host": "127.0.0.1", "port": 3485 }], "backends": 3;
connect E0 S0 127.0.0.1:3485;

# test: create topic (with subscription)
create topic test_top;
show topics;

create subscription top_sub on test_top;
show subs;
publish into test_top 123;
publish into test_top 1,2,3;
publish into test_top;
select * from top_sub;

# test: checkpoint/restart
checkpoint;

# test: restart/recover
disconnect S0;
close E0;
open E0;
connect E0 S0 127.0.0.1:3485;
select * from top_sub;

# test: create table (with subscription)
create table test (id int primary key, data int);
create subscription test_sub on test;
insert into test values (1, 10), (2, 20), (3, 30);
select * from test_sub;

# test: checkpoint/restart
checkpoint;

# test: restart/recover
disconnect S0;
close E0;
open E0;
connect E0 S0 127.0.0.1:3485;
select * from test_sub;
select * from top_sub;

drop topic test_top cascade;
drop table test cascade;

disconnect S0;
close E0;
