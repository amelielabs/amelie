#
open E0 "uuid": "00000000-0000-0000-0000-000000000001", "listen": [{ "host": "127.0.0.1", "port": 3485 }];
connect E0 S0 127.0.0.1:3485;

# test: create topic statement parsing
create topic;
create topic 1;
create topic;
create topic if exists;

# test: create topic
create topic test;
show topics;

# test: create topic (if exists)
create topic test;
create topic if not exists test;

# test: create topic description
create topic test2 description;
create topic test2 description 123;
create topic test2 description 'test test';
show topic test2;

# test: crud/query
insert into test values (123);
delete from test; 
select * from test;

# test: publish (no subscibers)
publish;
publish into;
publish into;
publish into 1;
publish into xyz;

publish into test;
publish into test 123;

# test: drop topic statement parsing
drop topic;
drop topic 123;

# test: drop topic
drop topic test;
drop topic test2;

# test: drop topic (if exists)
drop topic test;
drop topic if exists;
drop topic if exists test;

# test: alter topic statement parsing
create topic test;
show topics;

alter topic;
alter topic test;
alter topic test xyz;
alter topic test 1;

# test: alter topic rename to
alter topic test rename;
alter topic test rename to;
alter topic test rename to xyz;
show topics;

# test: alter topic rename to (if exists)
alter topic test rename to xyz;
alter topic if exists test rename to xyz;
show topics;

publish into xyz 123;
drop topic xyz;

drop topic test;

# test: alter topic description
create topic x;
alter topic x description '__renamed';
show topic x;
drop topic x;

disconnect S0;
close E0;
